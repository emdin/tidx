# Docker image tag to run in test-prod.
TIDX_IMAGE=reshmem/tidx:igra-testprod

# Public explorer domain served by Caddy with automatic Let's Encrypt TLS.
EXPLORER_DOMAIN=explore-test.igralabs.com
LETSENCRYPT_EMAIL=ops@igralabs.com
EXPLORER_BASE_URL=https://explore-test.igralabs.com/explore

# Blockscout source used to import verified contracts into the local explorer.
BLOCKSCOUT_SOURCE_URL=https://explorer.igralabs.com
BLOCKSCOUT_CHAIN_ID=38833
BLOCKSCOUT_IMPORT_INTERVAL_SECONDS=900

# PostgreSQL credentials for the tidx chain database.
POSTGRES_USER=tidx
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=tidx_igra

# Grafana admin password. Grafana is bound to localhost by default.
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Kaspa Borsh wRPC is expected on the Docker host loopback by default
# (127.0.0.1:17110). The proxy exposes it only on the Docker bridge address.
KASPA_WRPC_BORSH_PORT=17110
KASPA_PROXY_PORT=17111
KASPA_PROXY_BIND_HOST=172.18.0.1

# Optional container log level.
RUST_LOG=tidx=info
RUST_LOG_FORMAT=pretty
