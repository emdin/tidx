          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT block_num, idx, hash, `from`, `to`, value, gas_used FROM txs WHERE `from` = '$wallet_address' OR `to` = '$wallet_address' ORDER BY block_num DESC, idx DESC LIMIT 100",
