# Keep the prod compose project stable so Docker volume names do not depend on
# the checkout directory name.
COMPOSE_PROJECT_NAME=iidx-prod

# Immutable iidx/tidx image tag to run in prod.
# Replace with the release image your CI publishes, for example:
# TIDX_IMAGE=ghcr.io/igralabs/iidx:igra-ac8e120
TIDX_IMAGE=ghcr.io/igralabs/iidx:replace-with-release-tag

# Public explorer domain served by Caddy with automatic Let's Encrypt TLS.
EXPLORER_DOMAIN=explorer.igralabs.com
LETSENCRYPT_EMAIL=ops@igralabs.com
EXPLORER_BASE_URL=https://explorer.igralabs.com/explore

# Blockscout source used to import verified contracts into the local explorer.
BLOCKSCOUT_SOURCE_URL=https://explorer.igralabs.com
BLOCKSCOUT_CHAIN_ID=38833
BLOCKSCOUT_IMPORT_INTERVAL_SECONDS=900

# PostgreSQL credentials for the tidx chain database.
POSTGRES_USER=tidx
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=tidx_igra

# Grafana admin password. Grafana is bound to localhost by default and exposed
# through Caddy at /grafana only if the Caddyfile keeps that route enabled.
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password

# Kaspa Borsh wRPC is expected on the Docker host loopback by default
# (127.0.0.1:17110). The proxy exposes it only on the Docker bridge address.
KASPA_WRPC_BORSH_PORT=17110
KASPA_PROXY_PORT=17111
KASPA_PROXY_BIND_HOST=172.17.0.1

# Optional container log level.
RUST_LOG=tidx=info
RUST_LOG_FORMAT=pretty
